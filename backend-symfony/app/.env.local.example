# =====================================================
# .env.local.example - Template pour la PRODUCTION
# =====================================================
# Sur le VPS, copier ce fichier en .env.local et remplir
# les valeurs réelles (notamment le mot de passe SMTP).
#
# Symfony charge .env.local APRÈS .env (override).
# .env.local est gitignored : les secrets restent locaux.

###> app ###
# Environnement Symfony
APP_ENV=prod
APP_DEBUG=0

# URL publique de l'app (utilisée dans les liens des mails + URLs des photos)
APP_URL=https://novaville.fr
###< app ###

###> symfony/mailer ###
# SMTP OVH pour l'envoi des mails
# IMPORTANT : URL-encoder le @ de l'email (→ %40) et les caractères spéciaux du mot de passe
# Exemple si mot de passe = "MotDePasse@123" → "MotDePasse%40123"
MAILER_DSN=smtp://contact%40novaville.fr:CHANGE_ME_PASSWORD@ssl0.ovh.net:587
MAILER_FROM=contact@novaville.fr
###< symfony/mailer ###

###> nelmio/cors-bundle ###
# Origines autorisées pour CORS (localhost en dev + domaine prod)
CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1|novaville\.fr|www\.novaville\.fr)(:[0-9]+)?$'
###< nelmio/cors-bundle ###
